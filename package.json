{
  "name": "the-real-snipeit-mcp",
  "version": "0.1.5",
  "description": "MCP server for the Snipe-IT REST API — 100% endpoint coverage (read + write), hand-wrappers + OpenAPI codegen, stdio transport.",
  "license": "MIT",
  "author": "Manuel Guttmann",
  "type": "module",
  "bin": { "the-real-snipeit-mcp": "dist/index.js" },
  "main": "dist/index.js",
  "homepage": "https://github.com/mguttmann/the-real-snipeit-mcp#readme",
  "repository": { "type": "git", "url": "git+https://github.com/mguttmann/the-real-snipeit-mcp.git" },
  "bugs": { "url": "https://github.com/mguttmann/the-real-snipeit-mcp/issues" },
  "keywords": ["mcp", "model-context-protocol", "snipe-it", "snipeit", "asset-management", "it-asset-management", "claude", "anthropic", "openapi", "stdio"],
  "publishConfig": { "access": "public" },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md", ".env.example"],
  "scripts": {
    "build": "tsc",
    "build:mcpb": "bash scripts/build-mcpb.sh",
    "codegen": "tsx src/codegen/generate.ts",
    "refresh-spec": "bash scripts/refresh-spec.sh",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit --passWithNoTests",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "coverage": "vitest run --coverage",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prebuild": "npm run lint && npm run typecheck && npm run test:unit"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "dotenv": "^16.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.6"
  }
}
